{
  "expo": {
    "name": "Motion Coach",
    "slug": "motioncoachlab-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand-assets/icon/icon-1024.png",
    "splash": {
      "image": "./assets/brand-assets/logo/motioncoach-wordmark-splash-transparent.png",
      "imageWidth": 320,
      "resizeMode": "contain",
      "backgroundColor": "#e9f8fb"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.motioncoachlab.app",
      "icon": "./assets/brand-assets/icon/icon-1024.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Motion Coach uses location during your run to track distance and pace.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Motion Coach can track your run while the app is in background.",
        "NSHealthShareUsageDescription": "Motion Coach reads selected Health data to personalise training and recovery guidance.",
        "NSHealthUpdateUsageDescription": "Motion Coach writes completed workouts so your activity is reflected in Apple Health and rings.",
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true,
        "UIBackgroundModes": [
          "audio",
          "location"
        ]
      },
      "buildNumber": "4"
    },
    "android": {
      "package": "com.motioncoachlab.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand-assets/android/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/brand-assets/android/adaptive-icon-background.png",
        "monochromeImage": "./assets/brand-assets/android/adaptive-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/brand-assets/web/favicon.ico"
    },
    "owner": "butlox",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand-assets/logo/motioncoach-wordmark-splash-transparent.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#e9f8fb"
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-audio",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/brand-assets/icon/icon-1024.png",
          "color": "#6b8f41",
          "sounds": [
            "./assets/audio/cues/warmup_intro.wav",
            "./assets/audio/cues/warmup.wav",
            "./assets/audio/cues/prerun.wav",
            "./assets/audio/cues/run.wav",
            "./assets/audio/cues/walk.wav",
            "./assets/audio/cues/cooldown.wav",
            "./assets/audio/cues/summary.wav",
            "./assets/audio/cues/halfway.wav"
          ]
        }
      ]
    ]
  }
}
